{
  "schema": 1,
  "id": "tool-tts",
  "name": "TW-TTS Tool",
  "version": "1.0.0",
  "type": "tool",
  "description": "Expose speech and speech-control commands for the local TW-TTS UART module.",
  "targets": ["esp32s3"],
  "sources": ["src/mod_tool_tts.c", "src/tool_tts.c"],
  "headers": ["src/tool_tts.h"],
  "dependencies": ["core.tool_registry", "device.twtts"],
  "conflicts": [],
  "permissions": ["uart"],
  "tools": ["tts_say", "tts_control"],
  "services": [],
  "resources": {
    "tasks": 0,
    "gpio": [17, 18],
    "uart": [1],
    "psram_bytes_hint": 0,
    "flash_bytes_hint": 4096
  }
}
